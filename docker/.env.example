# .env.example — tom-and-jerry Docker environment
# Copy to .env and fill in your values:
#   cp docker/.env.example docker/.env
#
# Then start:
#   docker compose -f docker/docker-compose.yml up -d        # Tom only
#   docker compose -f docker/docker-compose.yml --profile jerry-cpu up -d
#   docker compose -f docker/docker-compose.yml --profile jerry-cuda up -d

# ─── Tailscale ────────────────────────────────────────────────────────────────
# Get an auth key from https://login.tailscale.com/admin/settings/keys
# Use a reusable key if running multiple containers, or ephemeral for one-shot.
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXX

# If Tom and Jerry have separate Tailscale accounts/tailnets, set both:
# JERRY_TS_AUTHKEY=tskey-auth-...

# ─── Tom (orchestrator) ───────────────────────────────────────────────────────
TOM_NAME=Tom
TOM_EMOJI=🐱
TOM_MODEL=claude-sonnet-4-6
TOM_GATEWAY_PORT=18789
TOM_GATEWAY_TOKEN=   # leave empty to auto-generate on first boot

# AI provider key — Anthropic by default
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXX

# ─── Jerry (executor) — fill in after tj onboard on Jerry, or run jerry-cpu/cuda profile ──
JERRY_NAME=Jerry
JERRY_EMOJI=🐭
JERRY_MODEL=llama3.2
JERRY_PROVIDER=ollama
JERRY_GATEWAY_PORT=18789
JERRY_GATEWAY_TOKEN=   # leave empty to auto-generate

# Models to pull at startup (comma-separated)
# Examples: llama3.2,mistral,codellama:13b,llava:13b
JERRY_OLLAMA_MODELS=llama3.2

# Jerry's Tailscale info (from Jerry's startup logs or `tj status` on Jerry)
JERRY_TAILSCALE_HOSTNAME=jerry-jerry-docker
JERRY_TAILSCALE_IP=100.x.y.z
JERRY_SSH_USER=root

# Tom's SSH public key (paste the contents of ~/.ssh/id_ed25519.pub here)
# Jerry will add this to its authorized_keys so Tom can SSH in for task delivery
TOM_SSH_PUBKEY=

# Reverse: Tom's Tailscale IP (for Jerry to know where to report back)
TOM_TAILSCALE_IP=100.a.b.c

# Wake-on-LAN (optional — for physical Jerry machines)
JERRY_WOL_ENABLED=false
JERRY_WOL_MAC=
JERRY_WOL_BROADCAST=

# Jerry node — Docker image (NVIDIA CUDA)
# Ollama with CUDA GPU acceleration + Node 22 + Tailscale + OpenClaw + tom-and-jerry
#
# Requires: nvidia-container-toolkit on the host
# https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/latest/install-guide.html
#
# Usage:
#   docker build -t calcifer-ai/jerry-cuda -f docker/jerry/Dockerfile.cuda .
#   docker run -d --gpus all \
#     -e TS_AUTHKEY=tskey-auth-... \
#     -e JERRY_NAME="GLaDOS" \
#     -e JERRY_EMOJI="🤖" \
#     calcifer-ai/jerry-cuda
#
# Tested with: RTX 3070 Ti, RTX 3090, RTX 4090

FROM nvidia/cuda:12.3.2-base-ubuntu22.04 AS base

# ── Prevent interactive prompts ───────────────────────────────────────────────
ENV DEBIAN_FRONTEND=noninteractive

# ── System dependencies ───────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    curl \
    socat \
    openssh-server \
    ca-certificates \
    tini \
    procps \
    gnupg \
    lsb-release \
  && rm -rf /var/lib/apt/lists/*

# ── Node.js 22 ────────────────────────────────────────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
  && apt-get install -y --no-install-recommends nodejs \
  && rm -rf /var/lib/apt/lists/*

# ── Tailscale ─────────────────────────────────────────────────────────────────
RUN curl -fsSL https://pkgs.tailscale.com/stable/ubuntu/jammy.noarmor.gpg \
      | tee /usr/share/keyrings/tailscale-archive-keyring.gpg > /dev/null \
  && curl -fsSL https://pkgs.tailscale.com/stable/ubuntu/jammy.tailscale-keyring.list \
      | tee /etc/apt/sources.list.d/tailscale.list \
  && apt-get update && apt-get install -y --no-install-recommends tailscale \
  && rm -rf /var/lib/apt/lists/*

# ── Ollama (with CUDA support — auto-detected at runtime) ─────────────────────
RUN curl -fsSL https://ollama.com/install.sh | sh

# ── OpenClaw ──────────────────────────────────────────────────────────────────
RUN npm install -g openclaw

# ── tom-and-jerry CLI ─────────────────────────────────────────────────────────
RUN npm install -g tom-and-jerry

# ── Runtime config dirs ───────────────────────────────────────────────────────
RUN mkdir -p /root/.openclaw /root/.tom-and-jerry /root/.ollama

# ── SSH server (for tj send over SSH from Tom) ────────────────────────────────
RUN mkdir -p /root/.ssh && chmod 700 /root/.ssh
RUN sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin prohibit-password/' /etc/ssh/sshd_config
RUN ssh-keygen -A

# ── Entrypoint ────────────────────────────────────────────────────────────────
COPY docker/jerry/entrypoint.sh /entrypoint.sh
COPY docker/jerry/pull-models.sh /pull-models.sh
RUN chmod +x /entrypoint.sh /pull-models.sh

EXPOSE 18789 11434 22

HEALTHCHECK --interval=30s --timeout=5s --start-period=90s \
    CMD curl -sf http://127.0.0.1:18789/health || exit 1

# Report CUDA visibility at startup
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility

ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
